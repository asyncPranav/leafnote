<%- include("partials/header") %>

  <div class="max-w-2xl mx-auto">

    <h1 class="text-2xl font-bold tracking-tight text-[#f0f0f2] mb-8">Edit Note</h1>

    <div class="bg-[#222224] border border-white/[0.07] rounded-2xl p-8">

      <form action="/edit/<%= note._id %>" method="POST" class="flex flex-col gap-6">

        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-[#6e6e7a] uppercase tracking-widest">Title</label>
          <input
            type="text"
            name="title"
            placeholder="Note title"
            value="<%= note.title %>"
            required
            class="bg-[#191919] border border-white/[0.07] rounded-xl px-4 py-3 text-sm text-[#f0f0f2] placeholder-[#6e6e7a]/50 outline-none focus:border-[#4ade80]/40 focus:ring-2 focus:ring-[#4ade80]/10 transition-all"
          >
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-[#6e6e7a] uppercase tracking-widest">Content</label>
          <textarea
            name="content"
            placeholder="Write your note..."
            rows="10"
            required
            class="bg-[#191919] border border-white/[0.07] rounded-xl px-4 py-3 text-sm text-[#f0f0f2] placeholder-[#6e6e7a]/50 outline-none focus:border-[#4ade80]/40 focus:ring-2 focus:ring-[#4ade80]/10 transition-all resize-y leading-relaxed"
          ><%= note.content %></textarea>
        </div>

        <div class="h-px bg-white/[0.06]"></div>

        <div class="flex items-center gap-3">
          <button type="submit"
            class="inline-flex items-center gap-2 text-sm font-semibold text-[#191919] px-5 py-2.5 rounded-xl bg-[#4ade80] border border-[#4ade80]/40 hover:opacity-85 transition-all cursor-pointer font-[inherit]">
            <i class="fa-solid fa-leaf"></i> Save Changes
          </button>
          <a href="/"
            class="inline-flex items-center gap-2 text-sm font-medium text-[#6e6e7a] px-5 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.07] hover:text-[#f0f0f2] hover:border-white/[0.14] transition-all no-underline">
            <i class="fa-solid fa-arrow-left"></i> Cancel
          </a>
        </div>

      </form>

    </div>

  </div>

<%- include("partials/footer") %>
